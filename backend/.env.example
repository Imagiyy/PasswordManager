#
# Copy this file to .env and fill in all values.
# The server will refuse to start if any required variable is missing.

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://vaultuser:vaultpass@localhost:5432/vaultdb

# ── JWT RS256 Key Pair ────────────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -pubout -in private.pem -out public.pem
#
# Paths are relative to the backend/ directory.
JWT_PRIVATE_KEY_PATH=./private.pem
JWT_PUBLIC_KEY_PATH=./public.pem

# Access token TTL in seconds (15 minutes)
JWT_ACCESS_EXPIRY=900

# ── Refresh Token ─────────────────────────────────────────
# Refresh token TTL in days
REFRESH_TOKEN_EXPIRY_DAYS=30

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Argon2id Server-Side Parameters ──────────────────────
# These are used to hash auth_key into auth_verifier on the server.
# This is SEPARATE from the client-side Argon2id that derives master_key.
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4
